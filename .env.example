# App Configuration
APP_ENVIRONMENT=Development

# Server Configuration
PORT=8080
BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# SPA OAuth return (OPTIONAL — leave empty for default template / demo behavior)
# When UNSET or empty: OAuth success callbacks return JSON on this API (Swagger, Postman, “see the tokens” demos).
# When SET (e.g. http://localhost:3000/auth/callback): success callbacks 302 to that URL with tokens in the URL #hash
# for a first-party browser SPA. Same routes; no breaking change for clones that never set this variable.
FRONTEND_OAUTH_CALLBACK_URL=

# Rate Limiting
RATE_LIMIT_TIMEFRAME_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=10

# MongoDB Configuration
MONGO_USERNAME=your_mongo_username
MONGO_PASSWORD=your_mongo_password
MONGO_CLUSTER_URI=your_cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=your_db_name

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# API Key for Testing
API_KEY=test-api-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# Line OAuth
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CALLBACK_URL=https://your-app.vercel.app/api/auth/line/callback
LINE_ACCOUNT_LINKING=strict/permissive

# Github Oauth
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret
GITHUB_CALLBACK_URL=https://your-app.vercel.app/api/auth/github/callback

# Discord Oauth
DISCORD_CLIENT_ID=your-client-id
DISCORD_CLIENT_SECRET=your-client-secret
DISCORD_CALLBACK_URL=https://your-app.vercel.app/api/auth/discord/callback

# Microsoft Oauth
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_CALLBACK_URL=https://your-app.vercel.app/api/auth/microsoft/callback

# MAX SESSIONS
MAX_SESSIONS = 5

# Mail Configuration (SMTP)
MAIL_HOST=your-mail-host
MAIL_PORT=your-mail-port
MAIL_USER=your-mail-user
MAIL_PASSWORD=your-mail-password
MAIL_FROM=your-mail-from
VERIFY_REDIRECT_URL= ...  ← optional, if set → redirect, else JSON

# Company Configuration
COMPANY_NAME=your-company-name
COMPANY_LOGO_URL=your-company-logo-url


# Stripe Configuration (see documentation/STRIPE.md)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_LIFETIME=price_...

# Auth Secrets (Optional)
RESET_PASSWORD_SECRET=your-reset-password-secret-min-32-chars

# Cloudflare R2 (S3-compatible uploads — optional until you use POST /api/upload)
# Create API token with Object Read & Write on the bucket; bind a custom domain or use the r2.dev public URL.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
# Public base URL for objects (no trailing slash), e.g. https://pub-xxxxx.r2.dev or https://cdn.yourdomain.com
R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
